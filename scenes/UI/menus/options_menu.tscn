[gd_scene load_steps=3 format=3]

[ext_resource type="Script" path="res://scripts/ui/menus/options_menu.gd" id="1_script"]
[ext_resource type="Script" path="res://scripts/ui/menus/fullscreen_toggle.gd" id="2_toggle"]

[sub_resource type="StyleBoxFlat" id="StyleBoxFlat_bg"]
bg_color = Color(0.949, 0.886, 0.729, 1)

[node name="OptionsMenu" type="Control"]
layout_mode = 3
anchors_preset = 15
anchor_right = 1.0
anchor_bottom = 1.0
grow_horizontal = 2
grow_vertical = 2
script = ExtResource("1_script")

[node name="Background" type="Panel" parent="."]
layout_mode = 1
anchors_preset = 15
anchor_right = 1.0
anchor_bottom = 1.0
grow_horizontal = 2
grow_vertical = 2
theme_override_styles/panel = SubResource("StyleBoxFlat_bg")

[node name="CenterContainer" type="CenterContainer" parent="."]
layout_mode = 1
anchors_preset = 15
anchor_right = 1.0
anchor_bottom = 1.0
grow_horizontal = 2
grow_vertical = 2

[node name="VBoxContainer" type="VBoxContainer" parent="CenterContainer"]
layout_mode = 2
theme_override_constants/separation = 40

[node name="TitleLabel" type="Label" parent="CenterContainer/VBoxContainer"]
layout_mode = 2
text = "OPTIONS"
horizontal_alignment = 1
theme_override_font_sizes/font_size = 48
theme_override_colors/font_color = Color(0.243, 0.153, 0.137, 1)

[node name="SettingsContainer" type="VBoxContainer" parent="CenterContainer/VBoxContainer"]
layout_mode = 2
theme_override_constants/separation = 16

[node name="FullscreenToggle" type="Button" parent="CenterContainer/VBoxContainer/SettingsContainer"]
layout_mode = 2
custom_minimum_size = Vector2(300, 0)
size_flags_horizontal = 4
text = "Fullscreen: OFF"
theme_override_font_sizes/font_size = 20
script = ExtResource("2_toggle")

[node name="BackButton" type="Button" parent="CenterContainer/VBoxContainer"]
layout_mode = 2
custom_minimum_size = Vector2(200, 0)
size_flags_horizontal = 4
text = "Back"
theme_override_font_sizes/font_size = 24

[connection signal="pressed" from="CenterContainer/VBoxContainer/BackButton" to="." method="_on_back_button_pressed"]
