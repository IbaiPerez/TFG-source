[ext_resource type="Script" path="res://scripts/turn_events/events/unlock_observatorio_event.gd" id="1_script"]

[resource]
script = ExtResource("1_script")
id = "unlock_observatorio"
title = "Cielos de la Tundra"
description = "[i]Las noches despejadas de la tundra revelan un cielo estrellado sin igual. Tus sabios proponen construir observatorios en las cumbres heladas para estudiar los astros. El conocimiento adquirido ampliará tus opciones estratégicas, pero mantener a los astrónomos en el frío será costoso.[/i]"
allow_skip = false
weight = 10.0
unique = true
