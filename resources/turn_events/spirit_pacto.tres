[resource]
script = ExtResource("1_script")
id = "spirit_pacto"
title = "Pacto con el Bosque"
description = "[i]Los espíritus del Santuario proponen un pacto ancestral: extenderán las raíces del bosque más allá de tus fronteras, reclamando territorio virgen para tu imperio. A cambio, solo piden que respetes la tierra conquistada.[/i]"
allow_skip = true
weight = 1.0
unique = false
