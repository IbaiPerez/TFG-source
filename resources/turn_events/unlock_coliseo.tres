[resource]
script = ExtResource("1_script")
id = "unlock_coliseo"
title = "Arquitectos del Espectáculo"
description = "[i]La fama de tu imperio atrae a arquitectos visionarios de tierras lejanas. Proponen construir un gran coliseo en tu megalópolis, un monumento que reduzca los costes de construcción en todo el imperio gracias a las técnicas que enseñarán a tus canteros.[/i]"
allow_skip = false
weight = 10.0
unique = true
