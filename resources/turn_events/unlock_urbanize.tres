[resource]
script = ExtResource("1_script")
id = "unlock_urbanize"
title = "Auge Urbano"
description = "[i]Tus aldeas prosperan y crecen sin cesar. Los maestros constructores y administradores más veteranos proponen un ambicioso plan: transformar las aldeas más desarrolladas en auténticas ciudades, con mercados, almacenes y puertos que impulsen tu civilización a una nueva era.[/i]"
